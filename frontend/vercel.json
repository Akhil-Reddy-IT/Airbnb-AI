{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://airbnb-ai-api.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://airbnb-ai-api.onrender.com/uploads/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
